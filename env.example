# Runtime (API/pages): use pooled connection
DATABASE_URL="postgresql://postgres:<password>@<host>:6543/postgres?sslmode=no-verify"

# Migrations (Prisma): use direct/session connection
DIRECT_URL="postgresql://postgres:<password>@<host>:5432/postgres?sslmode=no-verify"

# Supabase Auth (GoTrue)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<supabase-anon-key>"

# Page Agent proxy (server-side; keep API key private)
PAGE_AGENT_API_KEY="<dashscope-api-key>"
PAGE_AGENT_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# Optional: keep disabled in production unless you explicitly want the public login page to use it.
PAGE_AGENT_PROXY_ENABLED="false"

# Page Agent client config
NEXT_PUBLIC_PAGE_AGENT_MODEL="qwen3.5-plus"
NEXT_PUBLIC_PAGE_AGENT_LANGUAGE="zh-CN"
